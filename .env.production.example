# AI Gateway — production environment template (PH12/PH13).
# Copy to .env.production and fill in real values. NEVER commit the real file.
# This file lives ONLY on the VPS (/opt/ai-gateway/.env.production) — docker
# compose reads it on every deploy. The CD pipeline never touches it, so your
# provider keys and DB password never leave the server.
#   cp .env.production.example .env.production
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d
#
# IMAGE_TAG is injected by the CD workflow (commit sha); defaults to "latest"
# for manual runs — no need to set it here.

# --- Provider API keys (required) ---
GROQ_API_KEY=
# Mistral (console.mistral.ai) — free tier.
MISTRAL_API_KEY=
# Gemini — RAG embeddings ONLY (no longer a responder: Gemini Flash free tier is
# geo-blocked in the EEA; slot 3 moved to a 2nd Groq model, PH36/D-26).
GEMINI_API_KEY=
# Optional model overrides (defaults in backend/core/config.py):
# MISTRAL_MODEL=mistral-small-latest
# SCOUT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Postgres (used by compose for the db service + backend DATABASE_URL) ---
POSTGRES_USER=ai_gateway
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ai_gateway

# --- Backend ---
# Public origin of the site. Frontend and API share this origin (aaPanel
# terminates TLS and proxies to the bundled nginx), so CORS is not exercised in
# normal use — but set it correctly to your real domain.
CORS_ALLOW_ORIGINS=https://st.byn.sarl
# Set true once served over HTTPS (TLS) so session cookies are Secure.
COOKIE_SECURE=true
SESSION_TTL_HOURS=168
LOG_LEVEL=INFO

# Request / RAG limits (optional overrides; defaults live in core/config.py).
# MAX_MESSAGE_LENGTH=8000
# HISTORY_LIMIT=10
# SAVED_CHATS_LIMIT=3
# RAG_MAX_FILE_BYTES=5000000
# RAG_MAX_DOCUMENTS=10
# RAG_TOP_K=4
# EMBEDDING_MODEL=models/gemini-embedding-001

# NOTE: DATABASE_URL and CHROMA_PATH are set by docker-compose.yml for the
# backend container (Postgres service + the chroma volume) — do not set here.
