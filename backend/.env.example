# AI Gateway — backend configuration template.
# Copy to backend/.env and fill in real values. NEVER commit the real .env.

# --- Provider API keys (required) ---
# Responders
GROQ_API_KEY=your-groq-key
CEREBRAS_API_KEY=your-cerebras-key
SAMBANOVA_API_KEY=your-sambanova-key
# Judge / selector
GEMINI_API_KEY=your-gemini-key

# --- CORS (PH1) ---
# Comma-separated list of allowed frontend origins. Do NOT use "*" with credentials.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Request limits (PH1) ---
# Max characters allowed in a single user message.
MAX_MESSAGE_LENGTH=8000

# --- Responders (PH13/PH16) ---
# Global output token budget for responder models. Reasoning models need enough
# headroom or they return empty content. Default 2048.
RESPONDER_MAX_TOKENS=2048
# Cerebras runs GLM-4.7 (a reasoning model) → extra headroom so hidden reasoning
# never crowds out the visible answer.
CEREBRAS_MAX_TOKENS=4096

# --- Responder models (PH16, D-11) ---
# Each responder runs a distinct, truthfully-named model so Compare shows three
# genuinely different answers (Llama / GLM / DeepSeek) and the judge (Qwen)
# shares no family with any of them. Display names live in
# config/models_config.py. Override an id here to swap a model without code.
GROQ_MODEL=llama-3.3-70b-versatile
CEREBRAS_MODEL=zai-glm-4.7
SAMBANOVA_MODEL=DeepSeek-V3.1

# --- Database (PH4) ---
# Async SQLAlchemy URL. Dev (SQLite) default below; for Postgres use:
#   postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL=sqlite+aiosqlite:///./ai_gateway.db
# Interactions kept per user in history (sliding window).
HISTORY_LIMIT=10

# --- Auth / sessions (PH8) ---
# Set true in production (HTTPS) so session cookies are Secure.
COOKIE_SECURE=false
# Session lifetime, hours.
SESSION_TTL_HOURS=168

# --- Admin / quotas (PH15) ---
# Username granted admin (admin panel + unlimited quota) on registration.
ADMIN_USERNAME=admin
# Required code to register. Empty = registration disabled (admin creates accounts).
REGISTRATION_CODE=change-me-registration-code
# Default request quotas for non-admin accounts (Compare counts as 1 request).
DEFAULT_MAX_REQUESTS_PER_MINUTE=5
DEFAULT_MAX_REQUESTS_PER_DAY=30

# --- RAG (PH10) ---
# Persistent ChromaDB directory (created on first use).
CHROMA_PATH=./chroma_data
# Gemini embedding model (reuses GEMINI_API_KEY).
EMBEDDING_MODEL=models/gemini-embedding-001
# Upload + chunking limits.
RAG_MAX_FILE_BYTES=5000000
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4
RAG_MAX_DOCUMENTS=10

# --- Selector overrides (PH3; defaults live in config/selector_config.py) ---
# SELECTOR_MODEL=gemini-2.5-flash-lite
# SELECTOR_TIMEOUT=20
# SELECTOR_MAX_RETRIES=2
# SELECTOR_TEMPERATURE=0.1
# SELECTOR_MAX_TOKENS=1200
# SELECTOR_MIN_CONFIDENCE=0.65
